        <mxCell id="KG-8YlWCkpxqc-QcICXF-1" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;item_name确认&lt;/font&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;用户问题重写&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
