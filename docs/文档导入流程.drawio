        <mxCell id="GadEcI-um8SxzRVKOPGR-12" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;文档切分&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;arcSize=16;fontFamily=Helvetica;fontSize=12;fontColor=default;fillColor=none;gradientColor=none;" vertex="1" parent="GadEcI-um8SxzRVKOPGR-17">
