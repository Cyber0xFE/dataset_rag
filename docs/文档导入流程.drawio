        <mxCell id="GadEcI-um8SxzRVKOPGR-18" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;图片处理&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=default;align=center;verticalAlign=middle;arcSize=16;fontFamily=Helvetica;fontSize=12;fontColor=default;fillColor=none;gradientColor=none;" vertex="1" parent="GadEcI-um8SxzRVKOPGR-25">
