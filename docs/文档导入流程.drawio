        </mxCell>
        <mxCell id="GadEcI-um8SxzRVKOPGR-27" value="&lt;span style=&quot;font-size: 16px;&quot;&gt;item_name提取&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;arcSize=16;fontFamily=Helvetica;fontSize=12;fontColor=default;fillColor=none;gradientColor=none;" vertex="1" parent="GadEcI-um8SxzRVKOPGR-26">
